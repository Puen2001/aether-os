# config.env — voice pipeline configuration (no secrets in this file).
#
# Copy to config.env (same directory) and adjust. Add voice/config.env to your
# .gitignore — it holds machine-local values (mic index, model paths).
#
# Sourced by voice.sh AFTER it defines:
#   $ROOT          repo root (override with PAI_ROOT)
#   $VOICE_RUNTIME machine-local state dir (default ~/.config/personal-ai/voice)
# so both variables are available here. Secrets (API keys, bot tokens) go in
# $VOICE_RUNTIME/secrets.env — see secrets.env.example.

# --- Speech-to-text (whisper.cpp) -------------------------------------------
# whisper-cli binary; install with `brew install whisper-cpp` (or build from
# source) so it is on PATH, or set an absolute path here.
WHISPER_BIN="${WHISPER_BIN:-whisper-cli}"
# GGML model file. ggml-small is a good multilingual default; download from
# https://huggingface.co/ggerganov/whisper.cpp into $VOICE_RUNTIME/models/.
WHISPER_MODEL="$VOICE_RUNTIME/models/ggml-small.bin"
# "auto" detects the spoken language per turn (replies are always English —
# that lives in the persona, not here). Pin to "en" etc. to skip detection.
WHISPER_LANG="auto"

# --- Microphone --------------------------------------------------------------
# avfoundation audio device index for ffmpeg, e.g. ":0" = first audio device
# (typically "Built-in Microphone"). List devices with:
#   ffmpeg -f avfoundation -list_devices true -i ""
MIC_INDEX=":0"

# --- Vault whitelist ----------------------------------------------------------
# Space-separated vault names under <root>/vaults/ that the brain router may
# read during a voice session (passed as --add-dir). Keep this NARROW: every
# vault listed is content a voice turn could read aloud or send to a cloud
# model. Opt sensitive vaults in per-session, not here.
READ_VAULTS="vault1"
# export VAULTS_DIR="$ROOT/vaults"   # where the vaults live (telegram bridge; default shown)

# --- ElevenLabs (only used when TTS_PROVIDER=elevenlabs) ----------------------
# Model: eleven_multilingual_v2 = quality; eleven_turbo_v2_5 = faster/cheaper.
EL_MODEL="eleven_multilingual_v2"
# Your voice id from https://elevenlabs.io/app/voice-lab (the API key goes in
# $VOICE_RUNTIME/secrets.env, never here).
EL_VOICE_ID="<your-voice-id>"
EL_VOICE_NAME=""                           # informational only

# --- Brain backend ------------------------------------------------------------
# The LLM that answers each turn. Pick ONE backend with BRAIN_PROVIDER -- no
# provider is required to be installed, configure whichever you have:
#
#   api     any OpenAI-compatible /chat/completions endpoint. This is the
#           universal, provider-agnostic option:
#             - local + free + private: Ollama, LM Studio, llama.cpp, vLLM
#             - hosted: OpenAI, OpenRouter, Together, Groq, ...
#   cmd     pipe the prompt through any local chat CLI (BRAIN_CMD below)
#   claude  the Claude Code CLI (headless)        -- only if you use Claude Code
#   codex   the Codex CLI                          -- only if you use Codex
#
# Example: a fully local, free, offline brain via Ollama --
#   export BRAIN_PROVIDER=api
#   export BRAIN_API_BASE="http://localhost:11434/v1"
#   export BRAIN_MODEL="llama3.1"
#   (no API key needed for a local server)
export BRAIN_PROVIDER="${BRAIN_PROVIDER:-api}"

# api backend (BRAIN_PROVIDER=api). The API KEY, if any, goes in secrets.env.
export BRAIN_API_BASE="${BRAIN_API_BASE:-http://localhost:11434/v1}"   # Ollama default
export BRAIN_MODEL="${BRAIN_MODEL:-llama3.1}"

# cmd backend (BRAIN_PROVIDER=cmd): any command that reads a prompt on stdin
# and prints the reply, e.g. "ollama run llama3.1" or "llm -m gpt-4o-mini".
# export BRAIN_CMD="ollama run llama3.1"

VOICE_BRAIN="$ROOT/system/brain/router.py"
# Routing mode: auto picks per prompt; or force a backend. With BRAIN_PROVIDER
# set above, leave this on auto.
VOICE_BRAIN_MODE="${VOICE_BRAIN_MODE:-auto}"
VOICE_BRAIN_WORKSPACE="${VOICE_BRAIN_WORKSPACE:-$ROOT}"
VOICE_BRAIN_TIMEOUT="${VOICE_BRAIN_TIMEOUT:-150}"   # seconds; hard backstop per turn
# Only used by the claude / codex backends -- harmless to leave if unused.
VOICE_CLAUDE_CONFIG_DIR="${VOICE_CLAUDE_CONFIG_DIR:-${CLAUDE_CONFIG_DIR:-$HOME/.claude}}"
VOICE_CODEX_SANDBOX="${VOICE_CODEX_SANDBOX:-read-only}"  # voice sessions inspect, never edit

# --- TTS provider switch -------------------------------------------------------
# kokoro     = free, local, Apache-2 (default)
# elevenlabs = cloud, paid (set ELEVENLABS_API_KEY in secrets.env to use)
# say        = macOS built-in (no install; fallback only)
TTS_PROVIDER="${TTS_PROVIDER:-kokoro}"

# Kokoro (local). Model + voices files from the kokoro-onnx releases page:
# https://github.com/thewh1teagle/kokoro-onnx (download into the models dir).
KOKORO_PY="${VOICE_PYTHON:-$VOICE_RUNTIME/.venv/bin/python}"
KOKORO_SCRIPT="$ROOT/voice/kokoro-synth.py"
export KOKORO_MODEL="$VOICE_RUNTIME/models/kokoro/kokoro-v1.0.onnx"
export KOKORO_VOICES="$VOICE_RUNTIME/models/kokoro/voices-v1.0.bin"
export KOKORO_VOICE="${KOKORO_VOICE:-bm_daniel}"   # any voice id shipped in voices-v1.0.bin
export KOKORO_LANG="${KOKORO_LANG:-en-gb}"
# export KOKORO_SPEED=1.0                          # playback rate (kokoro-synth.py)

# Last-ditch fallback voice when the chosen TTS provider fails (macOS `say -v ?`
# lists what is installed).
SAY_FALLBACK_VOICE="${SAY_FALLBACK_VOICE:-Daniel}"

# --- VAD endpointing (wake-word turn capture) ----------------------------------
# Tune these by ear: too short silence_ms clips trailing words; too long stalls
# every turn. Threshold above ~0.6 is "louder/clearer speech only".
export VAD_SILENCE_MS="${VAD_SILENCE_MS:-800}"        # silence run that ends a turn
export VAD_MAX_UTT_MS="${VAD_MAX_UTT_MS:-30000}"      # hard cap (stuck-mic backstop)
export VAD_MIN_UTT_MS="${VAD_MIN_UTT_MS:-600}"        # below this, treat as misfire
export VAD_PRE_SPEECH_MS="${VAD_PRE_SPEECH_MS:-3000}" # silence-before-speech timeout
export VAD_THRESHOLD="${VAD_THRESHOLD:-0.5}"          # Silero speech-probability gate
# export VAD_DEVICE=""                                # leave unset = system default mic

# --- Awake-window (follow-up) ---------------------------------------------------
# After a reply, hold the daemon muted and VAD-listen for this many ms.
# If the user starts speaking, treat it as a follow-up turn without re-wake.
# Safe to leave on because the window is interruptible: pressing Enter during
# the follow-up listen cancels back to idle (await_or_cancel in voice.sh).
# Set to 0 to disable follow-ups; raise/lower to taste.
export FOLLOWUP_WINDOW_MS="${FOLLOWUP_WINDOW_MS:-8000}"

# --- Cancel / barge-in -----------------------------------------------------------
# There is no separate cancel key: Enter is the universal action key.
#   idle      -> Enter starts recording (or type text + Enter to send a typed turn)
#   recording -> Enter stops recording
#   thinking  -> Enter cancels the in-flight reply (stops token spend)
#   speaking  -> Enter stops playback
#   follow-up -> Enter returns to idle
# Wired via await_or_cancel(); cancel travels the trigger FIFO (handsfree) or
# stdin (non-handsfree). VOICE_BRAIN_TIMEOUT remains the hard backstop.

# --- Voice barge-in (speak over TTS) ----------------------------------------------
# When ON, you can start TALKING over the assistant's reply — a Silero VAD
# listens during playback, stops playback on your speech-onset, and captures
# your interruption as the next turn (no Enter, no re-wake). Handsfree only.
#
# Default OFF because of the self-trigger problem: with OPEN SPEAKERS the mic
# hears the assistant's own TTS and the VAD can false-trigger on it (there is
# no echo cancellation). With HEADPHONES the mic never hears the playback, so
# barge-in is clean — set BARGE_IN=1 when you're on headphones.
#   Speakers:   leave 0, or set 1 and raise BARGE_IN_THRESHOLD until self-trigger stops.
#   Headphones: set 1; 0.9 is plenty.
export BARGE_IN="${BARGE_IN:-0}"
export BARGE_IN_THRESHOLD="${BARGE_IN_THRESHOLD:-0.9}"   # Silero p>=this = user interrupting (high = fewer self-triggers)

# --- Handsfree / wake word ----------------------------------------------------------
# VOICE_HANDSFREE=1 (default) spawns capture.py: hold-key (right Option) +
# optional wake word + Enter fallback. Set 0 for the plain Enter-only loop.
# These are read by capture.py (a child process), so they must be exported:
# export VOICE_HANDSFREE=1
# export VOICE_WAKE_ENABLED=0    # 1 = openWakeWord listener inside capture.py
# export WAKE_MODEL=hey_jarvis   # stock openwakeword model; swap in your own .onnx to change the phrase
# export WAKE_THRESHOLD=0.6      # detection score gate
# export VOICE_HOTKEY=alt_r      # alt = either Option key; alt_r = right-only
