# secrets.env — credentials for the voice pipeline. PLACEHOLDERS ONLY here.
#
# Copy this file to $VOICE_RUNTIME/secrets.env (default:
# ~/.config/personal-ai/voice/secrets.env), fill in real values, then:
#   chmod 600 ~/.config/personal-ai/voice/secrets.env
# The runtime dir lives outside the repo, so the real file never enters git;
# never commit a filled-in copy anywhere.
#
# Every value is optional: leave a key blank to keep that integration off
# (kokoro and `say` TTS need no secrets at all).

# Brain API key (only when BRAIN_PROVIDER=api against a HOSTED endpoint --
# OpenAI, OpenRouter, Together, Groq, ...). Local servers (Ollama, LM Studio)
# need no key, so leave this blank for a fully local brain.
# `export` so it reaches the router subprocess (voice.sh sources this file).
export BRAIN_API_KEY=""

# ElevenLabs TTS (only for TTS_PROVIDER=elevenlabs).
# Create at https://elevenlabs.io -> Profile -> API Keys; enable the
# Text-to-Speech and Voices(read) scopes.
ELEVENLABS_API_KEY=""

# Telegram bridge (shared with the telegram pack; same VOICE_* runtime dir).
# Bot token: DM @BotFather on Telegram -> /newbot -> copy the token.
TELEGRAM_BOT_TOKEN=""

# Your numeric Telegram user id: DM @userinfobot and copy the "Id" it returns.
# Comma-separated for more than one allowed sender; everyone else is ignored.
TELEGRAM_ALLOWED_USERS=""
