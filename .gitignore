# Real secrets / config — only the *.example versions are committed
tools/*.env
!tools/*.env.example
system/denylist.txt

# Per-user local opt-in flag for auto-push (created by tools/setup-git.sh)
tools/.autopush-enabled

# Generated by `./aether init` (from the committed *.example)
.claude/settings.json

# Memory engine runtime state (the dirs are kept via .gitkeep)
system/memory/pending/*.json
system/memory/.last-sweep

# Maintainer-private notes (never ship)
MARKETING.md

# Runtime / state
*.log
logs/
.session
*.cache

# OS / editor
.DS_Store
Thumbs.db
*.swp
.idea/
.vscode/

# Python
__pycache__/
*.pyc
.venv/
venv/
