#!/usr/bin/env python3
"""dispatch-report — periodic digest of the dispatch-trace JSONL.

Reads the event log written by tools/dispatch-trace.py — resolved the same
way the logger resolves it: ${CLAUDE_CONFIG_DIR}/logs/dispatch.jsonl, falling
back to ~/.config/personal-ai/logs/dispatch.jsonl — filters to a time window,
and emits a tight markdown report covering:

  - headline numbers (prompts, dispatches, inline rate)
  - top dispatched specialist types
  - per-vault dispatch distribution
  - average prompts per day (cadence signal)
  - sessions that exceeded a dispatch threshold (over-dispatch flag)

SYSTEM.md sec. 5 keeps inline work as the ~90% case; this report makes that
rule falsifiable.

The report lands in the shared-knowledge vault (vaults/vault1/wiki/). The
repo root resolves from this script's location (tools/..), overridable via
the PAI_ROOT env var.

Usage:
    dispatch-report                 # last 7 days -> vaults/vault1/wiki/dispatch-report.md
    dispatch-report --since 30d     # last 30 days
    dispatch-report --all           # full log history
    dispatch-report --dry           # print to stdout, write nothing
"""
from __future__ import annotations
import argparse
import collections
import datetime as dt
import json
import os
import re
import sys
from pathlib import Path


def config_dir() -> Path:
    # Mirrors tools/dispatch-trace.py so reader and writer always agree.
    cfg = os.environ.get("CLAUDE_CONFIG_DIR")
    return Path(cfg) if cfg else (Path.home() / ".config" / "personal-ai")


def repo_root() -> Path:
    env = os.environ.get("PAI_ROOT")
    if env:
        return Path(env).expanduser().resolve()
    return Path(__file__).resolve().parent.parent


LOG = config_dir() / "logs" / "dispatch.jsonl"

OVER_DISPATCH_THRESHOLD = 5


def parse_since(s: str) -> dt.timedelta:
    m = re.match(r"^(\d+)([dh])$", s)
    if not m:
        raise ValueError(f"--since must be like '7d' or '24h', got: {s}")
    n, unit = int(m.group(1)), m.group(2)
    return dt.timedelta(days=n) if unit == "d" else dt.timedelta(hours=n)


def load_events(cutoff_ts: float | None):
    if not LOG.exists():
        return []
    out = []
    with LOG.open() as f:
        for line in f:
            try:
                d = json.loads(line)
            except json.JSONDecodeError:
                continue
            if cutoff_ts is not None and d.get("ts", 0) < cutoff_ts:
                continue
            out.append(d)
    return out


def summarize(events: list[dict], window_label: str, window_days: float) -> dict:
    prompts = [e for e in events if e.get("event") == "prompt"]
    dispatches = [e for e in events if e.get("event") == "dispatch"]
    turn_ends = [e for e in events if e.get("event") == "turn_end"]

    n_prompts = len(prompts)
    n_dispatches = len(dispatches)
    inline_pct = ((n_prompts - n_dispatches) / n_prompts * 100) if n_prompts else 0.0

    specialists = collections.Counter(e.get("subagent_type", "general-purpose") for e in dispatches)
    vaults_dispatch = collections.Counter(e.get("vault", "?") for e in dispatches)
    vaults_prompt = collections.Counter(e.get("vault", "?") for e in prompts)

    dispatches_by_session = collections.Counter(e.get("session_id") for e in dispatches)
    over = [(sid, n) for sid, n in dispatches_by_session.items() if n > OVER_DISPATCH_THRESHOLD]
    over.sort(key=lambda x: -x[1])

    avg_prompts_per_day = (n_prompts / window_days) if window_days else 0

    return {
        "window_label": window_label,
        "window_days": window_days,
        "n_prompts": n_prompts,
        "n_dispatches": n_dispatches,
        "n_turn_ends": len(turn_ends),
        "inline_pct": inline_pct,
        "specialists": specialists,
        "vaults_dispatch": vaults_dispatch,
        "vaults_prompt": vaults_prompt,
        "avg_prompts_per_day": avg_prompts_per_day,
        "over_dispatch_sessions": over,
    }


def render(s: dict) -> str:
    now = dt.datetime.now().strftime("%Y-%m-%dT%H:%M")
    today = dt.date.today().isoformat()

    lines = [
        "---",
        f"title: dispatch report — {today} ({s['window_label']})",
        "type: meta",
        "tags: [dispatch-trace, observability, housekeeping]",
        f"generated_at: {now}",
        "ip_clean: true",
        "---",
        "",
        f"# dispatch report — {today}",
        "",
        f"Window: **{s['window_label']}** · auto-generated by `tools/dispatch-report`.",
        "",
        "## Headline",
        "",
        f"- prompts (user turns): **{s['n_prompts']}**",
        f"- dispatches (specialist runs): **{s['n_dispatches']}**",
        f"- inline rate: **{s['inline_pct']:.1f}%** (target ≥ 90% per `system/SYSTEM.md` sec. 5)",
        f"- average prompts/day: **{s['avg_prompts_per_day']:.1f}**",
        "",
    ]

    if s["n_prompts"] == 0:
        lines.append("_no activity in this window._\n")
        return "\n".join(lines)

    lines.append("## Top specialists dispatched")
    lines.append("")
    if s["specialists"]:
        for k, v in s["specialists"].most_common(8):
            pct = (v / s["n_dispatches"] * 100) if s["n_dispatches"] else 0
            lines.append(f"- **{k}** — {v} ({pct:.0f}%)")
    else:
        lines.append("_no dispatches._")
    lines.append("")

    lines.append("## Activity by vault")
    lines.append("")
    all_vaults = set(s["vaults_prompt"]) | set(s["vaults_dispatch"])
    rows = []
    for v in sorted(all_vaults, key=lambda v: -s["vaults_prompt"].get(v, 0)):
        rows.append((v, s["vaults_prompt"].get(v, 0), s["vaults_dispatch"].get(v, 0)))
    lines.append("| vault | prompts | dispatches |")
    lines.append("|---|---:|---:|")
    for v, p, d in rows:
        lines.append(f"| `{v}` | {p} | {d} |")
    lines.append("")

    if s["over_dispatch_sessions"]:
        lines.append(f"## Over-dispatched sessions (> {OVER_DISPATCH_THRESHOLD} dispatches)")
        lines.append("")
        lines.append("Sessions where dispatch count crossed the threshold — review whether parallel work justified it, or if inline would have been cheaper.")
        lines.append("")
        for sid, n in s["over_dispatch_sessions"][:10]:
            lines.append(f"- `{sid[:8]}…` — {n} dispatches")
        lines.append("")

    interp = []
    if s["inline_pct"] < 80:
        interp.append("WARNING: inline rate below 80% — dispatching too freely; revisit the SYSTEM.md sec. 5 dispatch tiers.")
    elif s["inline_pct"] < 90:
        interp.append("inline rate between 80–90% — borderline; watch the trend.")
    else:
        interp.append(f"OK: inline rate at {s['inline_pct']:.0f}% — on target.")
    lines.append("## Interpretation")
    lines.append("")
    lines.extend(f"- {x}" for x in interp)
    lines.append("")

    return "\n".join(lines) + "\n"


def main(argv):
    ap = argparse.ArgumentParser(description=__doc__.splitlines()[0])
    g = ap.add_mutually_exclusive_group()
    g.add_argument("--since", default="7d", help="window (e.g. 7d, 24h, 30d). default: 7d")
    g.add_argument("--all", action="store_true", help="ignore window, summarize entire log")
    ap.add_argument("--dry", action="store_true", help="print to stdout; write nothing")
    args = ap.parse_args(argv)

    if args.all:
        cutoff = None
        window_label = "all-time"
        evs = load_events(None)
        if evs:
            span = (max(e["ts"] for e in evs) - min(e["ts"] for e in evs)) / 86400
            window_days = max(span, 1.0)
        else:
            window_days = 1.0
    else:
        delta = parse_since(args.since)
        cutoff = (dt.datetime.now() - delta).timestamp()
        window_label = f"last {args.since}"
        window_days = delta.total_seconds() / 86400

    events = load_events(cutoff)
    s = summarize(events, window_label, window_days)
    report = render(s)

    if args.dry:
        sys.stdout.write(report)
        return 0

    report_path = repo_root() / "vaults" / "vault1" / "wiki" / "dispatch-report.md"
    report_path.parent.mkdir(parents=True, exist_ok=True)
    report_path.write_text(report, encoding="utf-8")
    try:
        shown = report_path.relative_to(repo_root())
    except ValueError:
        shown = report_path
    print(
        f"wrote {shown} · window={s['window_label']} · "
        f"{s['n_prompts']} prompts · {s['n_dispatches']} dispatches · "
        f"inline {s['inline_pct']:.1f}%"
    )
    return 0


if __name__ == "__main__":
    sys.exit(main(sys.argv[1:]))
