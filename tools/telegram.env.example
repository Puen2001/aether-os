# telegram.env — credentials for out-of-band Telegram pings (telegram-send).
#
# Copy this file to telegram.env (same directory) and fill in the real values.
# Add telegram.env to .gitignore so the real token never enters git history.
#
# How to get the values:
#   1. Talk to @BotFather on Telegram -> /newbot -> get the bot token.
#   2. Message your new bot once, then visit
#      https://api.telegram.org/bot<TOKEN>/getUpdates to read your chat_id.
#
# Leave either value blank to disable Telegram entirely — telegram-send will
# print a short "not configured" notice and exit without error.

TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""
