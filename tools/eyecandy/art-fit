#!/usr/bin/env python3
"""art-fit <name> [rawfile] [--invert]

Downsample BIG ascii art into a small portrait box (18x8), by treating each
character as ink density and area-averaging — the right way to fit a large image
into a tiny box (clipping would just grab a corner). Reads <rawfile> or stdin;
writes ~/.config/personal-ai/art/<name>.txt and echoes the result.

Usage:
  pbpaste | art-fit logo               # from clipboard (macOS)
  art-fit avatar raw.txt --invert      # from a file, flip light/dark
"""
import os
import sys

W, H = 18, 8
RAMP = " .:-=+*#%@"   # light -> dense

_DENS = {".": .12, "'": .12, "`": .12, ",": .2, ":": .28, ";": .32, "-": .3,
         "~": .3, "\"": .2, "+": .5, "=": .5, "|": .5, "/": .45, "\\": .45,
         "*": .7, "o": .6, "x": .62, "c": .55, "(": .45, ")": .45, "#": .85,
         "%": .82, "@": .95, "$": .85, "0": .75, "8": .8}


def ink(ch):
    if ch in " \t\r\n\x00\xa0":
        return 0.0
    return _DENS.get(ch, 0.8)   # unknown dense glyph (e.g. a pasted pi) -> fairly dark


def main():
    args = [a for a in sys.argv[1:] if not a.startswith("-")]
    flags = [a for a in sys.argv[1:] if a.startswith("-")]
    if not args:
        sys.exit("usage: art-fit <name> [rawfile] [--invert]")
    name = args[0].lower()
    raw = (open(args[1], encoding="utf-8", errors="replace").read()
           if len(args) > 1 else sys.stdin.read())
    invert = "--invert" in flags

    lines = raw.replace("\r", "").rstrip("\n").split("\n")
    lines = [ln for ln in lines if ln.strip() != ""] or lines
    sh = len(lines)
    sw = max((len(ln) for ln in lines), default=0)
    if sh == 0 or sw == 0:
        sys.exit("empty input")
    B = [[ink(ln[c]) if c < len(ln) else 0.0 for c in range(sw)] for ln in lines]

    out = []
    for oy in range(H):
        r0, r1 = oy * sh // H, max(oy * sh // H + 1, (oy + 1) * sh // H)
        row = []
        for ox in range(W):
            c0, c1 = ox * sw // W, max(ox * sw // W + 1, (ox + 1) * sw // W)
            tot = n = 0
            for r in range(r0, r1):
                br = B[r]
                for c in range(c0, c1):
                    tot += br[c]
                    n += 1
            b = (tot / n) if n else 0.0
            if invert:
                b = 1.0 - b
            row.append(RAMP[min(len(RAMP) - 1, int(b * len(RAMP)))])
        out.append("".join(row).rstrip())

    d = os.path.expanduser("~/.config/personal-ai/art")
    os.makedirs(d, exist_ok=True)
    path = os.path.join(d, name + ".txt")
    with open(path, "w", encoding="utf-8") as f:
        f.write("\n".join(out) + "\n")
    sys.stderr.write(f"wrote {path}  ({W}x{H}, from {sw}x{sh})\n")
    print("\n".join(out))


if __name__ == "__main__":
    main()
