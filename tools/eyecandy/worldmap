# ── geo math ─────────────────────────────────────────────────────────────────
def haversine(a, b):
    (la1, lo1), (la2, lo2) = a, b
    r1, r2 = math.radians(la1), math.radians(la2)
    dla, dlo = math.radians(la2 - la1), math.radians(lo2 - lo1)
    h = math.sin(dla / 2) ** 2 + math.cos(r1) * math.cos(r2) * math.sin(dlo / 2) ** 2
    return 2 * 6371.0 * math.asin(min(1.0, math.sqrt(h)))


def bearing(a, b):
    (la1, lo1), (la2, lo2) = a, b
    r1, r2 = math.radians(la1), math.radians(la2)
    dlo = math.radians(lo2 - lo1)
    y = math.sin(dlo) * math.cos(r2)
    x = math.cos(r1) * math.sin(r2) - math.sin(r1) * math.cos(r2) * math.cos(dlo)
    return (math.degrees(math.atan2(y, x)) + 360) % 360


def compass(brg):
    return ["N", "NE", "E", "SE", "S", "SW", "W", "NW"][int((brg + 22.5) % 360 // 45)]


def gc_arc(a, b, n=24):
    (la1, lo1), (la2, lo2) = a, b
    p1, l1, p2, l2 = map(math.radians, (la1, lo1, la2, lo2))
    d = 2 * math.asin(min(1.0, math.sqrt(
        math.sin((p2 - p1) / 2) ** 2 + math.cos(p1) * math.cos(p2) * math.sin((l2 - l1) / 2) ** 2)))
    if d == 0:
        return [a]
    out = []
    for i in range(n + 1):
        f = i / n
        A, B = math.sin((1 - f) * d) / math.sin(d), math.sin(f * d) / math.sin(d)
        x = A * math.cos(p1) * math.cos(l1) + B * math.cos(p2) * math.cos(l2)
        y = A * math.cos(p1) * math.sin(l1) + B * math.cos(p2) * math.sin(l2)
        z = A * math.sin(p1) + B * math.sin(p2)
        out.append((math.degrees(math.atan2(z, math.hypot(x, y))),
                    math.degrees(math.atan2(y, x))))
    return out


# ── viewport ─────────────────────────────────────────────────────────────────
REGIONS = [
