class Viewport:
    def __init__(self, bbox):
        self.set(bbox)

    def set(self, bbox):
        self.lon0, self.lon1, self.lat0, self.lat1 = bbox

    def to_cell(self, lon, lat, MW, H):
        if not (self.lon0 <= lon <= self.lon1 and self.lat0 <= lat <= self.lat1):
            return None
        cx = int((lon - self.lon0) / (self.lon1 - self.lon0) * (MW - 1))
        cy = int((self.lat1 - lat) / (self.lat1 - self.lat0) * (H - 1))
        return cx, cy

    def center(self):
        return ((self.lat0 + self.lat1) / 2, (self.lon0 + self.lon1) / 2)

    def span(self):
        return self.lon1 - self.lon0, self.lat1 - self.lat0

    def zoom(self, f):
        clat, clon = self.center()
        dw, dh = self.span()
        dw, dh = dw * f / 2, dh * f / 2
        dw = max(4, min(180, dw))
        dh = max(2, min(85, dh))
        self.set((clon - dw, clon + dw, clat - dh, clat + dh))

    def pan(self, fx, fy):
        dw, dh = self.span()
        self.lon0 += dw * fx
        self.lon1 += dw * fx
        self.lat0 = max(-89, min(self.lat0 + dh * fy, 88))
        self.lat1 = max(-88, min(self.lat1 + dh * fy, 89))


# ── coastline (cached per viewport+size) ─────────────────────────────────────
def load_lines():
    try:
        d = json.load(open(DATA, encoding="utf-8"))
    except Exception:
        return []
    out = []
    for f in d.get("features", []):
        g = f.get("geometry") or {}
        if g.get("type") == "LineString":
            out.append(g["coordinates"])
        elif g.get("type") == "MultiLineString":
            out.extend(g["coordinates"])
    return out


LINES = load_lines()
_coast_cache = {}


def coastline_cells(vp, MW, H):
    key = (round(vp.lon0, 1), round(vp.lon1, 1), round(vp.lat0, 1), round(vp.lat1, 1), MW, H)
    if key in _coast_cache:
        return _coast_cache[key]
    PW, PH = MW * 2, H * 4
    dots = bytearray(PW * PH)

    def plot(x, y):
        if 0 <= x < PW and 0 <= y < PH:
            dots[y * PW + x] = 1

    lon0, lon1, lat0, lat1 = vp.lon0, vp.lon1, vp.lat0, vp.lat1
    sx, sy = (PW - 1) / (lon1 - lon0), (PH - 1) / (lat1 - lat0)
    for line in LINES:
        prev = None
        for lon, lat in line:
            inside = lon0 <= lon <= lon1 and lat0 <= lat <= lat1
            x, y = (lon - lon0) * sx, (lat1 - lat) * sy
            if prev and (inside or prev[2]):
                x0, y0, _ = prev
                steps = int(max(abs(x - x0), abs(y - y0))) + 1
                for i in range(steps + 1):
                    t = i / steps
                    plot(int(x0 + (x - x0) * t), int(y0 + (y - y0) * t))
            prev = (x, y, inside)
    cells = [[None] * MW for _ in range(H)]
    for r in range(H):
        by = r * 4
        for c in range(MW):
            bits, bx = 0, c * 2
            for dy in range(4):
                ro = (by + dy) * PW
                for dx in range(2):
                    if dots[ro + bx + dx]:
                        bits |= 1 << BITS[(dx, dy)]
            if bits:
                cells[r][c] = chr(0x2800 + bits)
    if len(_coast_cache) > 12:
        _coast_cache.clear()
    _coast_cache[key] = cells
    return cells


# ── terminator (day/night) ───────────────────────────────────────────────────
def subsolar():
    now = datetime.now(timezone.utc)
    n = now.timetuple().tm_yday
    decl = -23.44 * math.cos(math.radians(360.0 / 365.0 * (n + 10)))
    utc_h = now.hour + now.minute / 60.0 + now.second / 3600.0
    lon = -15.0 * (utc_h - 12.0)
    lon = (lon + 180) % 360 - 180
    return lon, decl


def is_night(lon, lat, sslon, ssdecl):
    h = math.radians(lon - sslon)
    elev = (math.sin(math.radians(lat)) * math.sin(math.radians(ssdecl))
            + math.cos(math.radians(lat)) * math.cos(math.radians(ssdecl)) * math.cos(h))
    return elev < -0.05


# ── layers + live feeds (background threads) ─────────────────────────────────
def mag_color(m):
    if m >= 6:
        return rgb(220, 70, 60)
    if m >= 5:
        return rgb(228, 110, 70)
    if m >= 4:
        return rgb(234, 158, 60)
    if m >= 2.5:
        return rgb(212, 180, 80)
    return rgb(150, 150, 110)


def gdacs_color(level):
    return {"Red": rgb(220, 70, 60), "Orange": rgb(234, 158, 60),
            "Green": rgb(150, 170, 110)}.get(level, rgb(160, 160, 110))


def _get(url, timeout=10):
    req = urllib.request.Request(url, headers={"User-Agent": "worldmap/2"})
    with urllib.request.urlopen(req, timeout=timeout) as resp:
        return json.load(resp)


def fetch_quakes():
    d = _get("https://earthquake.usgs.gov/earthquakes/feed/v1.0/summary/all_day.geojson")
    pts = []
    for f in d.get("features", []):
        c = (f.get("geometry") or {}).get("coordinates") or []
        p = f.get("properties") or {}
        if len(c) >= 2 and p.get("mag") is not None:
            pts.append({"lon": c[0], "lat": c[1], "w": p["mag"], "t": p.get("time", 0),
                        "glyph": "✸" if p["mag"] >= 5 else "◉", "color": mag_color(p["mag"]),
                        "label": f"M{p['mag']:.1f}", "place": p.get("place") or "-",
                        "detail": f"depth {c[2]:.0f}km" if len(c) > 2 else "", "id": f.get("id", ""),
                        "url": p.get("url", "")})
    pts.sort(key=lambda q: q["t"], reverse=True)
    return pts


def fetch_gdacs():
    d = _get("https://www.gdacs.org/gdacsapi/api/events/geteventlist/EVENTS4APP")
    pts = []
    for f in d.get("features", []):
        c = (f.get("geometry") or {}).get("coordinates") or []
        p = f.get("properties") or {}
        if len(c) >= 2:
            lvl = p.get("alertlevel", "Green")
            pts.append({"lon": c[0], "lat": c[1], "w": p.get("alertscore", 1) or 1,
                        "t": 0, "glyph": "▴", "color": gdacs_color(lvl),
                        "label": f"{p.get('eventtype','?')} {lvl}",
                        "place": p.get("name") or p.get("country") or "-",
                        "detail": (p.get("description") or "")[:60], "id": str(p.get("eventid", "")),
                        "url": p.get("url", {}).get("report", "") if isinstance(p.get("url"), dict) else "",
                        "level": lvl})
    return pts


def fetch_gdelt():
    # GEO 2.0 GeoJSON — empty-safe: any failure/format issue → no points.
    try:
        url = ("https://api.gdeltproject.org/api/v2/geo/geo?query=(conflict%20OR%20protest%20OR%20"
               "disaster)&format=GeoJSON&timespan=1d&maxpoints=60")
        d = _get(url, timeout=12)
    except Exception:
        return []
    pts = []
    for f in d.get("features", []):
        c = (f.get("geometry") or {}).get("coordinates") or []
        p = f.get("properties") or {}
        if len(c) >= 2:
            nm = p.get("name") or "event"
            pts.append({"lon": c[0], "lat": c[1], "w": p.get("count", 1) or 1, "t": 0,
                        "glyph": "✚", "color": rgb(150, 175, 210), "label": "news",
                        "place": nm.split(",")[0][:40], "detail": nm[:60],
                        "id": nm, "url": p.get("shareimage", "")})
    return pts


