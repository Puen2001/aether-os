def ago(ms):
    s = max(0, time.time() - ms / 1000.0)
    return f"{int(s/60)}m" if s < 3600 else (f"{int(s/3600)}h" if s < 86400 else f"{int(s/86400)}d")


# ── frame compositor ─────────────────────────────────────────────────────────
def frame(st, cols, rows, fc):
    FEEDW = 28 if cols >= 70 else 0
    MW = cols - FEEDW - (3 if FEEDW else 0)
    H = rows - 1
    if MW < 24 or H < 8:
        MW, FEEDW, H = cols, 0, max(1, rows - 1)
    vp = st.vp
    coast = coastline_cells(vp, MW, H)
    grid = [[(coast[r][c], COAST) if coast[r][c] else (" ", None) for c in range(MW)]
            for r in range(H)]

    # terminator night wash (under everything)
    if TERMINATOR["enabled"]:
        sslon, ssdecl = subsolar()
        for r in range(H):
            lat = vp.lat1 - (r + 0.5) / H * (vp.lat1 - vp.lat0)
            for c in range(MW):
                lon = vp.lon0 + (c + 0.5) / MW * (vp.lon1 - vp.lon0)
                if is_night(lon, lat, sslon, ssdecl):
                    ch, col = grid[r][c]
                    if col is None:
                        grid[r][c] = ("⠂", NIGHT) if (r + c) % 7 == 0 else (" ", None)
                    elif col == COAST:
                        grid[r][c] = (ch, rgb(86, 78, 52))
        sc = vp.to_cell(sslon, ssdecl, MW, H)
        if sc:
            grid[sc[1]][sc[0]] = ("☼", rgb(245, 220, 140))

    with _lock:
        layers = [(ly, list(ly["pts"])) for ly in LAYERS]

    # home + great-circle arcs to significant quakes
    sig = []
    for ly, pts in layers:
        if ly["name"] == "quakes" and ly["enabled"]:
            sig = [p for p in pts if p["w"] >= 4.5][:5]
    for p in sig:
        for (alat, alon) in gc_arc(HOME, (p["lat"], p["lon"]), 22):
            cc = vp.to_cell(alon, alat, MW, H)
            if cc and grid[cc[1]][cc[0]][0] == " ":
                grid[cc[1]][cc[0]] = ("⠂", ARC)
    hc = vp.to_cell(HOME[1], HOME[0], MW, H)
    if hc:
        grid[hc[1]][hc[0]] = ("⌂", HOMEC)

    # layer markers + ping rings (freshest of each layer)
    for ly, pts in layers:
        if not ly["enabled"]:
            continue
        for i, p in enumerate(pts[:8]):
            cc = vp.to_cell(p["lon"], p["lat"], MW, H)
            if not cc:
                continue
            radius = ((fc + i * 3) % 14) * 0.55
            if radius >= 1:
                for a in range(0, 360, 24):
                    rx = int(cc[0] + radius * math.cos(math.radians(a)))
                    ry = int(cc[1] + radius * 0.5 * math.sin(math.radians(a)))
                    if 0 <= rx < MW and 0 <= ry < H and grid[ry][rx][0] in (" ", coast[ry][rx] if coast[ry][rx] else " "):
                        grid[ry][rx] = ("⠂", p["color"])
        for i, p in enumerate(pts[:200]):
            cc = vp.to_cell(p["lon"], p["lat"], MW, H)
            if not cc:
                continue
            col = p["color"]
            if i < 4 and (fc // 3) % 2:
                col = rgb(255, 240, 210)
            grid[cc[1]][cc[0]] = (p.get("glyph", "●"), col)
    # ISS trail
    if any(ly["enabled"] and ly["name"] == "ISS" for ly, _ in layers):
        for (tlon, tlat) in _iss_trail[:-1]:
            cc = vp.to_cell(tlon, tlat, MW, H)
            if cc and grid[cc[1]][cc[0]][0] == " ":
                grid[cc[1]][cc[0]] = ("⠂", rgb(70, 120, 140))

    # scan sweep
    sweep = fc % MW if MW else 0
    for r in range(H):
        ch, col = grid[r][sweep]
        if col == COAST:
            grid[r][sweep] = (ch, COAST_HOT)

    # cursor + nearest marker
    cur = vp.to_cell(st.cursor[1], st.cursor[0], MW, H)
    nearest = None
    best = 1e18
    for ly, pts in layers:
        if not ly["enabled"]:
            continue
        for p in pts:
            d = haversine((st.cursor[0], st.cursor[1]), (p["lat"], p["lon"]))
            if d < best:
                best, nearest = d, (ly, p)
    if cur:
        grid[cur[1]][cur[0]] = ("⌖", CURSORC)

    # ── render map rows + side panel ──
    panel = build_panel(st, layers, nearest, MW, H, FEEDW)
    out = ["\x1b[H"]
    for r in range(H):
        line, last = [], ""
        for c in range(MW):
            ch, col = grid[r][c]
            if col and col != last:
                line.append(col)
                last = col
            elif not col and last:
                line.append(R)
                last = ""
            line.append(ch)
        if last:
            line.append(R)
        if FEEDW:
            line.append(f" {MUT}|{R} ")
            line.append(panel[r] if r < len(panel) else "")
        line.append("\x1b[K")
        out.append("".join(line))
        out.append("\n")

    # status bar
    active = "".join(ly["key"] for ly in LAYERS if ly["enabled"]) + ("5" if TERMINATOR["enabled"] else "")
    reg = REGIONS[st.region][0]
    al = f"{rgb(228,110,70)}ALERTS{R}" if ALERTS_ON else f"{MUT}alerts off{R}"
    src = "OFFLINE" if OFFLINE else "live"
    out.append(f"{MUT}layers[{active}] {reg} {src} {al}  ? help  q quit{R}\x1b[K")
    return "".join(out)


def build_panel(st, layers, nearest, MW, H, FEEDW):
    if not FEEDW:
        return []
    lines = []
    if st.show_help:
        lines = [f"{BRASS}{BD}KEYS{R}", f"{MUT}{'-'*FEEDW}{R}",
                 f"{INK}1-5{R} toggle layer", f"{INK}+ -{R} zoom",
                 f"{INK}h j k l{R} pan", f"{INK}↑↓←→{R} move cursor",
                 f"{INK}Enter{R} inspect  {INK}Esc{R} unpin", f"{INK}r{R} region",
                 f"{INK}a{R} alerts  {INK}L{R} legend", f"{INK}q{R} quit"]
        return lines
    if st.show_legend:
        lines = [f"{BRASS}{BD}LAYERS{R}", f"{MUT}{'-'*FEEDW}{R}"]
        for ly in LAYERS:
            on = f"{ly['color']}{ly['glyph']}{R}" if ly["enabled"] else f"{MUT}·{R}"
            n = len(ly["pts"])
            age = _last.get(ly["name"])
            a = f"{int(time.time()-age)}s" if age else "-"
            lines.append(f"{on} {INK if ly['enabled'] else MUT}{ly['key']} {ly['name']:<9}{R}{MUT}{n:>3} {a}{R}")
        t = f"{rgb(245,220,140)}☀{R}" if TERMINATOR["enabled"] else f"{MUT}·{R}"
        lines.append(f"{t} {INK}5 day/night{R}")
        return lines
    if st.pinned:
        p = st.pinned
        d = haversine(HOME, (p["lat"], p["lon"]))
        b = bearing(HOME, (p["lat"], p["lon"]))
        lines = [f"{BRASS}{BD}INSPECT{R}", f"{MUT}{'-'*FEEDW}{R}",
                 f"{p['color']}{p.get('glyph','◉')}{R} {INK}{BD}{p['label']}{R}",
                 f"{INK}{p['place'][:FEEDW]}{R}", f"{MUT}{p.get('detail','')[:FEEDW]}{R}",
                 f"{MUT}{d:.0f} km {compass(b)} of home{R}",
                 f"{MUT}{ago(p['t']) if p['t'] else ''}{R}", "",
                 f"{MUT}Esc to release{R}"]
        return lines
    # default feed: merged significant events
    lines = [f"{BRASS}{BD}LIVE FEED{R}", f"{MUT}{'-'*FEEDW}{R}"]
    if nearest:
        ly, p = nearest
        d = haversine((st.cursor[0], st.cursor[1]), (p["lat"], p["lon"]))
        lines.append(f"{MUT}> nearest {d:.0f}km{R}")
        lines.append(f"{p['color']}{p.get('glyph','◉')}{R} {INK}{p['label']} {p['place'][:FEEDW-10]}{R}")
        lines.append("")
    merged = []
    for ly, pts in layers:
        if ly["enabled"]:
            for p in pts[:10]:
                merged.append((ly, p))
    merged.sort(key=lambda x: x[1].get("w", 0), reverse=True)
    for ly, p in merged[: max(0, H - len(lines))]:
        place = p["place"]
        if len(place) > FEEDW - 9:
            place = place[: FEEDW - 10] + "."
        lines.append(f"{p['color']}{p.get('glyph','◉')}{R} {INK}{p['label']:<5}{R} {INK}{place}{R}")
    return lines


# ── main loop ────────────────────────────────────────────────────────────────
def main():
    if not LINES:
        sys.stdout.write(f"no coastline data at {DATA}\n"
                         "(Natural Earth 1:110m coastline GeoJSON — see tools/eyecandy/README.md)\n")
        return 1
    _load_fired()
    if not OFFLINE:
        threading.Thread(target=scheduler, daemon=True).start()
    if _fd is not None:
        tty.setcbreak(_fd)
    sys.stdout.write("\x1b[?25l\x1b[2J")
    sys.stdout.flush()
    global ALERTS_ON
    st = State()
    fc = 0
    while True:
        cols, rows = shutil.get_terminal_size((100, 30))
        sys.stdout.write(frame(st, cols, rows, fc))
        sys.stdout.flush()
        fc += 1
        k = read_key(0.12)
        if k is None:
            continue
        if k == "q":
            restore()
        elif k in ("1", "2", "3", "4"):
            ly = LAYERS[int(k) - 1]
            ly["enabled"] = not ly["enabled"]
        elif k == "5":
            TERMINATOR["enabled"] = not TERMINATOR["enabled"]
        elif k in ("+", "="):
            st.vp.zoom(0.7)
        elif k in ("-", "_"):
            st.vp.zoom(1.43)
        elif k == "h":
            st.vp.pan(-0.18, 0)
        elif k == "l":
            st.vp.pan(0.18, 0)
        elif k == "k":
            st.vp.pan(0, 0.18)
        elif k == "j":
            st.vp.pan(0, -0.18)
        elif k == "r":
            st.region = (st.region + 1) % len(REGIONS)
            st.vp.set(REGIONS[st.region][1])
            st.cursor = list(st.vp.center())
        elif k in ("UP", "DOWN", "LEFT", "RIGHT"):
            dw, dh = st.vp.span()
            stp_lon, stp_lat = dw / 24, dh / 24
            if k == "UP":
                st.cursor[0] = min(89, st.cursor[0] + stp_lat)
            elif k == "DOWN":
                st.cursor[0] = max(-89, st.cursor[0] - stp_lat)
            elif k == "LEFT":
                st.cursor[1] -= stp_lon
            else:
                st.cursor[1] += stp_lon
        elif k == "ENTER":
            cols, rows = shutil.get_terminal_size((100, 30))
            FEEDW = 28 if cols >= 70 else 0
            MW = cols - FEEDW - (3 if FEEDW else 0)
            Hh = rows - 1
            with _lock:
                cand = [(ly, p) for ly in LAYERS if ly["enabled"] for p in list(ly["pts"])]
            if cand:
                cand.sort(key=lambda x: haversine((st.cursor[0], st.cursor[1]), (x[1]["lat"], x[1]["lon"])))
                st.pinned = cand[0][1]
                st.show_legend = st.show_help = False
        elif k == "ESC":
            st.pinned = None
        elif k == "a":
            ALERTS_ON = not ALERTS_ON
        elif k == "L":
            st.show_legend = not st.show_legend
        elif k == "?":
            st.show_help = not st.show_help


if __name__ == "__main__":
    try:
        sys.exit(main())
    finally:
        restore()
