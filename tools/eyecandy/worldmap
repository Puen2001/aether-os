_lock = threading.Lock()
_last = {}


def scheduler():
    due = {ly["name"]: 0 for ly in LAYERS}
    while True:
        now = time.time()
        for ly in LAYERS:
            if OFFLINE:
                continue
            if now >= due[ly["name"]]:
                try:
                    pts = ly["fetch"]()
                    with _lock:
                        ly["pts"] = pts
                        _last[ly["name"]] = time.time()
                    if ly["name"] in ("quakes", "disasters"):
                        check_alerts(ly, pts)
                except Exception:
                    pass
                due[ly["name"]] = now + ly["interval"]
        time.sleep(1)


# ── alerts ───────────────────────────────────────────────────────────────────
ALERTS_ON = os.environ.get("WORLDMAP_ALERTS", "0") == "1"
_fired = {}
_alert_times = []


def _load_fired():
    global _fired
    try:
        _fired = json.load(open(ALERT_STATE))
    except Exception:
        _fired = {}


def _save_fired():
    try:
        os.makedirs(CFG, exist_ok=True)
        json.dump(_fired, open(ALERT_STATE, "w"))
    except Exception:
        pass


def check_alerts(layer, pts):
    if not ALERTS_ON or not os.path.exists(TELEGRAM):
        return
    for p in pts:
        eid = f"{layer['name']}:{p['id']}"
        if eid in _fired:
            continue
        hit = False
        if layer["name"] == "quakes":
            d = haversine(HOME, (p["lat"], p["lon"]))
            if p["w"] >= 6.0 or (p["w"] >= 4.5 and d <= 1000):
                hit = True
        elif layer["name"] == "disasters" and p.get("level") == "Red":
            hit = True
        if not hit:
            continue
        now = time.time()
        _alert_times[:] = [t for t in _alert_times if now - t < 3600]
        if len(_alert_times) >= 6:
            return
        msg = f"worldmap: {p['label']} — {p['place']}"
        if layer["name"] == "quakes":
            msg += f" ({haversine(HOME,(p['lat'],p['lon'])):.0f} km from home)"
        try:
            subprocess.run([TELEGRAM, msg], timeout=10,
                           stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
            _fired[eid] = now
            _alert_times.append(now)
            _save_fired()
        except Exception:
            pass


# ── input ────────────────────────────────────────────────────────────────────
def read_key(timeout):
    if _fd is None:
        time.sleep(timeout)
        return None
    r, _, _ = select.select([_fd], [], [], timeout)
    if not r:
        return None
    ch = os.read(_fd, 1).decode("utf-8", "ignore")
    if ch == "\x1b":
        r2, _, _ = select.select([_fd], [], [], 0.002)
        if r2:
            seq = os.read(_fd, 2).decode("utf-8", "ignore")
            return {"[A": "UP", "[B": "DOWN", "[C": "RIGHT", "[D": "LEFT"}.get(seq, "ESC")
        return "ESC"
    if ch in ("\r", "\n"):
        return "ENTER"
    return ch


